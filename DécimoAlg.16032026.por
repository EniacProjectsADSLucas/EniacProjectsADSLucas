programa {
  funcao inicio() {
    //Laço de Repetição
    //o enquanto sempre ou nunca entra na condição de repetição
    inteiro contador= 1

    enquanto(contador <= 5) {
      escreva("Repetição = ", contador,"\n")
      contador = contador + 1 //contador ++ = contador = contador + 1
    }
  }
}
